<Window
    x:Class="CSD.Views.NotificationSendWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="发送通知"
    Closed="Window_Closed">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="发送通知"
            FontSize="28"
            FontWeight="SemiBold"
            Margin="0,0,0,16" />

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="24"
            Margin="0,0,0,12">
            <ToggleSwitch
                x:Name="UrgentToggle"
                Header="强调通知"
                OnContent="打开"
                OffContent="关闭" />
            <CheckBox
                x:Name="PersistentCheckBox"
                Content="常驻展示"
                VerticalAlignment="Center" />
        </StackPanel>

        <TextBox
            x:Name="ContentBox"
            Grid.Row="2"
            PlaceholderText="请输入强调通知的内容..."
            AcceptsReturn="True"
            TextWrapping="Wrap"
            MinHeight="100"
            MaxHeight="200"
            Margin="0,0,0,12" />

        <Button
            x:Name="SendButton"
            Grid.Row="3"
            Content="&#x24D8; 发送通知"
            HorizontalAlignment="Left"
            MinWidth="140"
            Click="SendButton_Click"
            Margin="0,0,0,16"
            Style="{StaticResource AccentButtonStyle}" />

        <Border
            Grid.Row="4"
            CornerRadius="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Padding="16"
            Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                    <TextBlock Text="&#x1F4CC;" FontSize="16" VerticalAlignment="Center" />
                    <TextBlock
                        Text="常驻通知管理"
                        FontSize="16"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock
                    x:Name="PersistentEmptyText"
                    Text="暂无常驻通知"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Visibility="Visible" />
                <StackPanel
                    x:Name="PersistentListPanel"
                    Visibility="Collapsed"
                    Spacing="6" />
            </StackPanel>
        </Border>

        <Border
            Grid.Row="5"
            CornerRadius="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Padding="16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,16">
                    <TextBlock Text="&#x1F550;" FontSize="16" VerticalAlignment="Center" />
                    <TextBlock
                        Text="消息记录"
                        FontSize="16"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel
                    x:Name="HistoryEmptyPanel"
                    HorizontalAlignment="Center"
                    Spacing="8">
                    <TextBlock
                        Text="&#x1F4E8;"
                        FontSize="40"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Text="暂无发送记录"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="14" />
                </StackPanel>
                <ScrollViewer
                    x:Name="HistoryScrollViewer"
                    Visibility="Collapsed"
                    MaxHeight="200"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel
                        x:Name="HistoryListPanel"
                        Spacing="6" />
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>
