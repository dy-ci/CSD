<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>CSD</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x86;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <PublishProfile Condition="'$(PublishProfile)'=='' and '$(Platform)'!='' and Exists('Properties\PublishProfiles\win-$(Platform).pubxml')">win-$(Platform).pubxml</PublishProfile>
    <UseWinUI>true</UseWinUI>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <WindowsPackageType>None</WindowsPackageType>
    <EnableMsixTooling>true</EnableMsixTooling>
	<SelfContained>true</SelfContained>
	<WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <Nullable>enable</Nullable>
    <!-- 版本号配置 -->
    <Version>0.0.3</Version>
    <AssemblyVersion>0.0.3.0</AssemblyVersion>
    <FileVersion>0.0.3.0</FileVersion>
    <AssemblyTitle>Classworks Desktop</AssemblyTitle>
    <Description>Classworks Desktop Client</Description>
    <Company>dy.ci</Company>
    <Product>Classworks Desktop</Product>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="CSD.Tests\**" />
    <Content Remove="CSD.Tests\**" />
    <Page Remove="CSD.Tests\**" />
    <None Remove="CSD.Tests\**" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\SplashScreen.scale-200.png" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\LockScreenLogo.scale-200.png" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\Square150x150Logo.scale-200.png" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\Square44x44Logo.scale-200.png" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\Square44x44Logo.targetsize-24_altform-unplated.png" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\StoreLogo.png" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\Wide310x150Logo.scale-200.png" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\Classworks.ico" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\app.ico" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\zhaishis.png" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\saskia.jpeg" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\wuyuan.jpeg" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="icons\ic_device_matebook.ico" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="icons\Classworks.ico" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="icons\ic_gallery_cloud_synchronization.ico" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="icons\ic_public_folder.ico" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="icons\ic_public_refresh.ico" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="icons\ic_statusbar_alarm.ico" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\MaterialDesignIconsDesktop.ttf" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\sounds\**\*.mp3" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <Manifest Include="$(ApplicationManifest)" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="ClassIsland-master\**\*.cs" />
    <EmbeddedResource Remove="ClassIsland-master\**\*" />
    <None Remove="ClassIsland-master\**\*" />
    <Page Remove="ClassIsland-master\**\*.xaml" />
    <ApplicationDefinition Remove="ClassIsland-master\**\*.xaml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="H.NotifyIcon.WinUI" Version="2.0.0" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.28000.1839" />
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="2.0.1" />
    <PackageReference Include="SocketIOClient" Version="4.0.4" />
    <PackageReference Include="System.Management" Version="10.0.8" />
  </ItemGroup>

  <!-- Publish Properties -->
  <PropertyGroup>
    <PublishReadyToRun Condition="'$(Configuration)' == 'Debug'">False</PublishReadyToRun>
    <PublishReadyToRun Condition="'$(Configuration)' != 'Debug'">True</PublishReadyToRun>
    <PublishTrimmed Condition="'$(Configuration)' == 'Debug'">False</PublishTrimmed>
    <PublishTrimmed Condition="'$(Configuration)' != 'Debug'">True</PublishTrimmed>
  </PropertyGroup>
</Project>
